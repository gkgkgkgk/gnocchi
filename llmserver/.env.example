# Copy to .env and fill in real values. .env is gitignored.

# --- LLM provider ---
# Legacy OpenAI key (Phase 0-1 still uses gpt-4o).
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic key (Phase 2+ swaps everything to Claude).
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Database (Phase 1+, once we replace Supabase) ---
# Points at homeserver postgres. Local dev: postgres on localhost.
DATABASE_URL=postgresql://gnocchi:gnocchi@127.0.0.1:5432/gnocchi

# --- Storage ---
# Where uploaded recipe images land. In the container this is a bind mount
# to /var/lib/gnocchi/images on the host (see serverkepets/apps.nix).
IMAGE_STORAGE_DIR=/data/images

# --- Server ---
PORT=8001
LOG_LEVEL=info
