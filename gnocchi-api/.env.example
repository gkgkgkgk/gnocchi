# Copy to .env and fill in real values. .env is gitignored.

# LLM provider — Phase 1 still uses OpenAI; Phase 2 swaps to Anthropic.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres.
# Dev: the flake's shellHook exports this from the local ./.pg cluster.
# Prod: injected by the serverkepets registry from `apps.nix db = "gnocchi"`.
DATABASE_URL=postgresql+asyncpg:///gnocchi?host=/tmp

# Where uploaded recipe photos land.
# Dev: repo-local ./.data/images (auto-created on startup).
# Prod: /data/images (container's bind-mounted /var/lib/gnocchi/images).
IMAGE_STORAGE_DIR=./.data/images

PORT=8001
