# Copy to .env and fill in. EXPO_PUBLIC_* is baked into the client at build
# time and is visible to anyone with the app — DO NOT put secrets here.

# --- Backend API (Phase 1+) ---
# During local dev: point at the FastAPI server on your machine.
# On the homeserver: point at the tailnet hostname (e.g. http://homeserver:8083)
# or the LAN IP. This is the ONLY endpoint the frontend needs after Phase 1.
EXPO_PUBLIC_API_URL=http://localhost:8001

# --- Legacy Supabase (Phase 0 only; removed in Phase 1) ---
# EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Legacy split-API URL (Phase 0 only) ---
# EXPO_PUBLIC_LLM_API_URL=http://localhost:8001
