# Copy to .env and fill in.
# EXPO_PUBLIC_* is baked into the client at build time.

# Backend API base URL.
# Local dev: point at the FastAPI server on your machine (or another).
# Production build (inside the frontend container): leave EMPTY. Caddy
# proxies /api/* to the backend over loopback, so the frontend just uses
# relative URLs and doesn't care where the backend lives.
EXPO_PUBLIC_API_URL=http://localhost:8001
